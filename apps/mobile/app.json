{
  "expo": {
    "name": "PosterLink",
    "slug": "posterlink-mobile",
    "version": "1.0.0",
    "scheme": "com.maxmini.posterlink",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maxmini.posterlink",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "포스터 촬영을 위해 카메라 권한이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "갤러리에서 포스터를 선택하기 위해 권한이 필요합니다.",
        "NSFaceIDUsageDescription": "빠른 로그인을 위해 생체 인증이 필요합니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.maxmini.posterlink",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-camera",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2563EB",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "supabaseUrl": "https://zxndgzsfrgwahwsdbjdj.supabase.co",
      "supabaseAnonKey": "sb_publishable_RQL3QuN9fmETURVzmm9Lfg_usBexkd1",
      "eas": {
        "projectId": "dd58cb12-9739-4dfb-bcda-6bc4947094b0"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "maxmini"
  }
}
