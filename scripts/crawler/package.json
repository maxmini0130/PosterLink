{
  "name": "posterlink-crawler",
  "version": "1.0.0",
  "description": "PosterLink 공공기관 포스터 크롤러",
  "type": "module",
  "scripts": {
    "test": "node --test src/*.test.js",
    "crawl": "node src/index.js",
    "crawl:dry": "node src/index.js --dry-run",
    "upload": "node src/upload-to-supabase.js",
    "list": "node src/index.js --list",
    "ai:export": "node src/export-poster-ai-dataset.js",
    "ai:train": "node ml/run-python.js train_poster_classifier.py",
    "ai:predict": "node ml/run-python.js predict_poster.py",
    "repair:images": "node src/repair-missing-poster-images.js",
    "repair:wa-youth": "node src/repair-wa-mark-youth-images.js",
    "refresh:site": "node src/refresh-site-posters.js",
    "storage:orphans": "node src/cleanup-orphan-storage.js",
    "audit:current": "node src/audit-current-posters.js",
    "embed:backfill": "node src/backfill-poster-embeddings.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.2",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "dayjs": "^1.11.0",
    "dotenv": "^16.4.0",
    "iconv-lite": "^0.7.2",
    "p-queue": "^8.0.0",
    "winston": "^3.11.0",
    "ws": "^8.20.0"
  }
}
