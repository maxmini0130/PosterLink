# Supabase 설정 (service_role 키 사용 — RLS 우회)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# 크롤러 봇 계정 UUID (Supabase Auth에서 생성 후 profiles에 role=operator로 등록)
# 없으면 빈칸으로 두어도 됨 (created_by=null)
CRAWLER_USER_ID=

# AI poster verification. By default, unverified images are rejected.
# Set OPENAI_API_KEY in production if you want the crawler to collect posters.
OPENAI_API_KEY=
POSTER_IMAGE_CLASSIFIER=auto
OPENAI_POSTER_IMAGE_MODEL=gpt-5-mini
POSTER_IMAGE_MIN_CONFIDENCE=0.65
POSTER_IMAGE_ALLOW_UNVERIFIED=0
POSTER_LOCAL_MODEL_PATH=
POSTER_LOCAL_MODEL_THRESHOLD=0.65
POSTER_AI_PYTHON=python
POSTER_CONTENT_VERIFIER=auto
OPENAI_POSTER_CONTENT_MODEL=gpt-5-mini
POSTER_CONTENT_MIN_CONFIDENCE=0.6
POSTER_CONTENT_ALLOW_UNVERIFIED=0
POSTER_CONTENT_ALLOW_ON_ERROR=0
POSTER_IMAGE_RULE_MIN_SCORE=45

# AI field verification (deadline/organization name accuracy check)
POSTER_FIELD_VERIFIER=auto
OPENAI_POSTER_FIELD_MODEL=gpt-5-mini
POSTER_FIELD_VERIFIER_MIN_CONFIDENCE=0.6
POSTER_FIELD_VERIFIER_ALLOW_ON_ERROR=1

# Semantic embeddings for recommendation (title+summary -> pgvector)
POSTER_EMBEDDER=auto
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
