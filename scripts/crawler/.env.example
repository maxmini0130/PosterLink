# Supabase 설정 (service_role 키 사용 — RLS 우회)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# 크롤러 봇 계정 UUID (Supabase Auth에서 생성 후 profiles에 role=operator로 등록)
# 없으면 빈칸으로 두어도 됨 (created_by=null)
CRAWLER_USER_ID=

# Optional: AI image classifier. If OPENAI_API_KEY is set and this is not "off",
# the crawler checks whether each image is actually a public poster/flyer.
OPENAI_API_KEY=
POSTER_IMAGE_CLASSIFIER=auto
OPENAI_POSTER_IMAGE_MODEL=gpt-5-mini
POSTER_IMAGE_MIN_CONFIDENCE=0.65
