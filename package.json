{
  "name": "posterlink-monorepo",
  "version": "0.1.0",
  "description": "PosterLink - 공공 포스터 애그리게이션 플랫폼",
  "private": true,
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:mobile": "pnpm --filter @posterlink/mobile start",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "collect": "tsx scripts/collect-posters.ts",
    "collect:youth": "tsx scripts/collect-posters.ts youth",
    "collect:central": "tsx scripts/collect-posters.ts central",
    "collect:local": "tsx scripts/collect-posters.ts local",
    "collect:subsidy": "tsx scripts/collect-posters.ts subsidy"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "prettier": "^3.0.0",
    "eslint": "^8.0.0",
    "tsx": "^4.0.0",
    "dotenv": "^16.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.0.0"
  }
}
